__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
build/
dist/
.DS_Store

# Only examples/sample-kanuri/ is committed; other delivery folders are local.
examples/*
!examples/sample-kanuri/
!examples/sample-kanuri/**

# Inside the sample, exclude the binary tarball and any alt out_* dirs.
# The rendered card.md and summary.md inside out/ ARE tracked so the generated
# dataset card is browsable on GitHub.
examples/sample-kanuri/out/*.tar.gz
examples/sample-kanuri/out_*/
